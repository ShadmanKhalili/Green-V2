# =============================================================================
# Environment variables required by Vite at build time.
# Copy to `.env.local` for local dev. Set the same names in Vercel for prod.
# =============================================================================

# Gemini AI (used by src/services/geminiService.ts for the AI Executive Summary
# and answer-coherence checks). Get a key at https://aistudio.google.com/apikey
# Vite injects this via `define` in vite.config.ts (process.env.GEMINI_API_KEY +
# process.env.API_KEY).
GEMINI_API_KEY=

# Firebase web config lives in firebase-applet-config.json and is committed.
# Web API keys are NOT secrets — security is enforced by firestore.rules + the
# Authentication > Authorized domains list. No env vars needed here.
